  "keyFeatures": [
    "Non-custodial MPC wallets with Turnkey/Fireblocks integration",
    "Natural language spending policies with real-time enforcement",
    "Financial hallucination prevention policy firewall",
    "Support for 9 AI frameworks (MCP, LangChain, OpenAI, Vercel AI, CrewAI, etc.)",
    "Virtual Visa/Mastercard issuance via Lithic",
    "Agent-to-agent escrow with cryptographic mandate chains",
    "Multi-chain support (Base, Polygon, Ethereum, Arbitrum, Optimism)",
    "KYC/AML compliance with Persona and Elliptic",
    "Double-entry audit ledger with cryptographic proofs",
    "Protocol compliance (AP2, TAP, UCP, A2A, x402)"
  ],
  "publicApiSurface": [
    "SardisClient.agents.create() - Create AI agent with wallet",
    "SardisClient.wallets.create() - Create MPC wallet with policies",
    "SardisClient.payments.create() - Execute policy-validated payment",
    "SardisClient.policies.create() - Define natural language spending rules",
    "SardisClient.cards.issue() - Issue virtual Visa/Mastercard",
    "SardisClient.holds.create() - Create payment hold for escrow",
    "SardisClient.approvals.request() - Request human approval for transaction",
    "SardisClient.compliance.verify() - Run KYC/AML checks",
    "SardisClient.groups.create() - Create agent group with shared budget",
    "SardisClient.transactions.list() - Query transaction history",
    "SardisClient.spending.summary() - Get spending analytics",
    "@sardis/mcp-server - MCP server for Claude/Cursor integration",
    "sardis_pay() - MCP tool for executing payments",
    "sardis_check_policy() - MCP tool for policy validation",
    "POST /api/v2/agents - REST API agent creation",
    "POST /api/v2/wallets - REST API wallet creation",
    "POST /api/v2/payments - REST API payment execution",
    "POST /api/v2/policies - REST API policy management",
    "GET /api/v2/spending - REST API spending analytics"
  ]
